{
  "name": "SchulterPlan",
  "version": 2,
  "public": true,
  "rewrites": [
    {
      "source": "/surgery-dashboard",
      "destination": "/surgery-dashboard.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/data/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
