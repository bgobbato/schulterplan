{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "SchulterPlan design tokens. Source of truth for any framework. Mirrors tokens.css 1:1.",
  "color": {
    "bg": {
      "base":      { "value": "#000000" },
      "baseAlt":   { "value": "#0a0a0f" },
      "surface":   { "value": "#18181b" },
      "card":      { "value": "rgba(39,39,42,0.7)" },
      "cardHover": { "value": "rgba(63,63,70,0.5)" },
      "glass":     { "value": "rgba(24,24,27,0.6)" }
    },
    "border": {
      "default": { "value": "rgba(255,255,255,0.08)" },
      "hover":   { "value": "rgba(255,255,255,0.15)" }
    },
    "text": {
      "primary":   { "value": "#fafafa" },
      "secondary": { "value": "#a1a1aa" },
      "muted":     { "value": "#71717a" }
    },
    "brand": {
      "primary":      { "value": "#17c5b0", "$description": "Implantcast teal" },
      "primaryHover": { "value": "#14b8a6" },
      "primaryGlow":  { "value": "rgba(23,197,176,0.25)" },
      "primarySoft":  { "value": "rgba(23,197,176,0.12)" },
      "accent":       { "value": "#f5a623", "$description": "Gold — toggle-on" },
      "accentSoft":   { "value": "rgba(245,166,35,0.12)" },
      "accentGlow":   { "value": "rgba(245,166,35,0.30)" },
      "info":         { "value": "#7dd3fc", "$description": "Used in logo gradient" }
    },
    "semantic": {
      "danger":  { "value": "#f31260" },
      "success": { "value": "#17c964" },
      "warning": { "value": "#f5a524" }
    },
    "contactMap": {
      "embedded":  { "value": "#1e78c8" },
      "contact":   { "value": "#008232" },
      "near":      { "value": "#17c964" },
      "noContact": { "value": "#3c3c41" }
    },
    "measure": {
      "$description": "6 rotating colors for 3D measurement spheres/lines",
      "cyan":   { "value": "#00ccff" },
      "orange": { "value": "#ff6644" },
      "yellow": { "value": "#ffcc00" },
      "purple": { "value": "#cc44ff" },
      "green":  { "value": "#44ff88" },
      "pink":   { "value": "#ff4488" }
    }
  },

  "radius": {
    "sm":   { "value": "8px" },
    "md":   { "value": "12px" },
    "lg":   { "value": "16px" },
    "xl":   { "value": "24px" },
    "pill": { "value": "999px" }
  },

  "shadow": {
    "sm":     { "value": "0 2px 8px rgba(0,0,0,0.30)" },
    "md":     { "value": "0 4px 16px rgba(0,0,0,0.40)" },
    "lg":     { "value": "0 8px 32px rgba(0,0,0,0.50)" },
    "glow":   { "value": "0 0 20px rgba(23,197,176,0.25)" },
    "accent": { "value": "0 0 16px rgba(245,166,35,0.30)" }
  },

  "blur": {
    "glass": { "value": "16px" }
  },

  "motion": {
    "ease":          { "value": "cubic-bezier(0.4, 0, 0.2, 1)" },
    "duration": {
      "fast":   { "value": "0.2s" },
      "normal": { "value": "0.3s" }
    },
    "press": {
      "$description": "transform on :active",
      "value": "scale(0.97)"
    },
    "hoverLift": {
      "$description": "transform on hover for primary buttons",
      "value": "translateY(-1px)"
    }
  },

  "font": {
    "family": {
      "sans": { "value": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif" }
    },
    "weight": {
      "light":      { "value": 300 },
      "regular":    { "value": 400 },
      "medium":     { "value": 500 },
      "semibold":   { "value": 600 },
      "bold":       { "value": 700 },
      "extrabold":  { "value": 800 }
    },
    "size": {
      "xxs":  { "value": "9px"  },
      "xs":   { "value": "10px" },
      "sm":   { "value": "11px" },
      "base": { "value": "12px" },
      "md":   { "value": "13px" },
      "lg":   { "value": "14px" },
      "xl":   { "value": "16px" },
      "2xl":  { "value": "18px" },
      "3xl":  { "value": "22px" },
      "4xl":  { "value": "32px" }
    },
    "tracking": {
      "tight":      { "value": "-0.3px" },
      "sectionLbl": { "value": "1.2px",  "$description": "uppercase section labels" },
      "kbdLbl":     { "value": "1px",    "$description": "small control labels" },
      "tag":        { "value": "0.5px" }
    }
  },

  "space": {
    "1":  { "value": "4px"  },
    "2":  { "value": "6px"  },
    "3":  { "value": "8px"  },
    "4":  { "value": "10px" },
    "5":  { "value": "12px" },
    "6":  { "value": "14px" },
    "7":  { "value": "16px" },
    "8":  { "value": "20px" },
    "9":  { "value": "24px" },
    "10": { "value": "32px" }
  },

  "z": {
    "base":    { "value": 1 },
    "sidebar": { "value": 10 },
    "topbar":  { "value": 20 },
    "toast":   { "value": 100 },
    "modal":   { "value": 200 }
  },

  "component": {
    "topbar": {
      "height":      { "value": "60px" },
      "heightSmall": { "value": "52px" }
    },
    "sidebar": {
      "leftWidth":  { "value": "280px" },
      "rightWidth": { "value": "290px" }
    },
    "ctrlBtn": {
      "size": { "value": "36px" }
    }
  }
}
